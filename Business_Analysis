# ---------------- YEARLY ANALYSIS ---------------- #
def yearly_analysis(wb):
    df = get_data(wb)

    month_sales = df.groupby(["Year", "Month", "Month_Name"], sort=False).agg(
        Total_Sales=("Total Amount", "sum")
    ).reset_index()

    month_sales = month_sales.sort_values(["Year", "Month"])

    month_sales["Running_Total"] = month_sales["Total_Sales"].cumsum()

    ws = get_or_create_sheet(wb, "Yearly Analysis")
    ws.range("A:I").clear()
    ws.range("A1").value = month_sales

def day_wise_sales(wb):
    df = get_data(wb)


    if "Day" not in df.columns:
        df["Day"] = pd.to_datetime(df["Order Date"], errors="coerce").dt.day

    df = df.dropna(subset=["Day"])

    df["Day"] = df["Day"].astype(int)

    pivot_df = df.pivot_table(
        index=["Year", "Month_Name"],
        columns="Day",
        values="Total Amount",
        aggfunc="sum",
        fill_value=0
    ).reset_index()

    print(pivot_df.head())
    try:
        ws = wb.sheets["Day Wise Sales"]
    except:
        ws = wb.sheets.add("Day Wise Sales")

    ws.range("A1").expand().clear()
    ws.range("A1").value = pivot_df



# ---------------- BONUS BUSINESS ANALYSIS ---------------- #
def top_customers(wb):
    df = get_data(wb)

    top = df.groupby("Customer Name")["Total Amount"].sum().nlargest(10).reset_index()

    ws = get_or_create_sheet(wb, "Customer Analysis")
    ws.range("AC:AF").clear()
    ws.range("AC1").value = top


def top_products(wb):
    df = get_data(wb)

    top = df.groupby("Product ID")["Total Amount"].sum().nlargest(10).reset_index()

    ws = get_or_create_sheet(wb, "Product_analysis")
    ws.range("R:U").clear()
    ws.range("R1").value = top


